---
import { getCollection } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const fmt = (d: Date) =>
  d.toLocaleDateString("es-CO", { year: "numeric", month: "short", day: "numeric", timeZone: "UTC" });
---

<BlogLayout
  title="blog"
  description="Blog de Juan Felipe Rodríguez Galindo — notas sobre cloud, backend, IA aplicada y software libre."
  path="/blog"
>
  <h1 class="blog-title">~/blog</h1>
  <p class="blog-intro dim">
    notas sobre cloud, backend, IA aplicada y software libre — cortas y al grano, como un buen commit.
    <a class="blog-timeline-link" href="/timeline">ver la línea de tiempo →</a>
  </p>

  <ul class="post-list">
    {posts.map((post) => (
      <li class="post-item">
        <a class="post-link" href={`/blog/${post.id}`}>
          <span class="post-title">{post.data.title}</span>
          <time class="post-date" datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
        </a>
        <p class="post-desc">{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <p class="post-tags">{post.data.tags.map((t) => <span class="post-tag">#{t}</span>)}</p>
        )}
      </li>
    ))}
  </ul>
</BlogLayout>

<style>
  .blog-title { color: var(--fg-bright); font-size: clamp(26px, 5vw, 34px); text-shadow: 0 0 12px var(--glow); }
  .blog-intro { color: var(--fg-dim); margin: 8px 0 30px; }
  .blog-timeline-link { color: var(--link); text-decoration: none; border-bottom: 1px dotted var(--link); white-space: nowrap; }
  .blog-timeline-link:hover { color: var(--fg-bright); text-shadow: 0 0 8px var(--glow); }
  .post-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 26px; }
  .post-item { border-left: 2px solid var(--fg-dim); padding-left: 16px; }
  .post-link { text-decoration: none; display: flex; justify-content: space-between; gap: 12px; flex-wrap: wrap; align-items: baseline; }
  .post-title { color: var(--accent); font-weight: 700; font-size: 17px; }
  .post-link:hover .post-title { color: var(--fg-bright); text-shadow: 0 0 8px var(--glow); }
  .post-date { color: var(--fg-dim); font-size: 13px; }
  .post-desc { color: var(--fg); margin: 6px 0 0; line-height: 1.6; }
  .post-tags { margin-top: 6px; display: flex; gap: 10px; flex-wrap: wrap; }
  .post-tag { color: var(--fg-dim); font-size: 12.5px; }
</style>
