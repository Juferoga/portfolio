---
import Terminal from "../components/Terminal.astro";
import GuiMode from "../components/GuiMode.astro";
import "../styles/global.css";
import { PROFILE } from "../data/profile";
import { getGithubStats } from "../data/github";
import { getCollection } from "astro:content";

const ghStats = await getGithubStats("Juferoga");

// Últimos posts del blog para el comando `blog` de la terminal
const blogPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5)
  .map((p) => ({ title: p.data.title, url: `/blog/${p.id}`, date: p.data.date.toISOString().slice(0, 10) }));

// Analítica GoatCounter: open source, sin cookies, sin datos personales (no requiere banner).
const GOATCOUNTER = "https://juferoga.goatcounter.com/count";

const person = {
  "@type": "Person",
  "@id": "https://juferoga.pro/#person",
  name: PROFILE.name,
  givenName: "Juan Felipe",
  familyName: "Rodríguez Galindo",
  alternateName: PROFILE.handle,
  jobTitle: PROFILE.role,
  worksFor: { "@type": "Organization", name: "Banco de Bogotá" },
  alumniOf: { "@type": "CollegeOrUniversity", name: "Universidad Distrital Francisco José de Caldas" },
  knowsAbout: ["Cloud Computing", "AWS", "Backend", "Java", "Python", "GNU/Linux", "Inteligencia Artificial"],
  knowsLanguage: ["es", "en"],
  url: "https://juferoga.pro",
  image: "https://juferoga.pro/assets/photos/avatar.jpg",
  email: `mailto:${PROFILE.contact.email}`,
  address: { "@type": "PostalAddress", addressLocality: "Bogotá", addressCountry: "CO" },
  sameAs: PROFILE.socials.map((s) => s.url),
};

// ProfilePage + WebSite: tipos que Google reconoce para páginas de perfil personal
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://juferoga.pro/#website",
      url: "https://juferoga.pro",
      name: "juferoga.pro",
      inLanguage: "es",
      publisher: { "@id": "https://juferoga.pro/#person" },
    },
    {
      "@type": "ProfilePage",
      "@id": "https://juferoga.pro/#profilepage",
      url: "https://juferoga.pro",
      isPartOf: { "@id": "https://juferoga.pro/#website" },
      dateModified: new Date().toISOString(),
      mainEntity: person,
    },
  ],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{`${PROFILE.name} — ${PROFILE.title} · ${PROFILE.handle}@portfolio:~$`}</title>
    <meta name="description" content={`${PROFILE.name} — ${PROFILE.role}. Portafolio interactivo tipo terminal.`} />
    <meta name="author" content={PROFILE.name} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="profile" />
    <meta property="profile:first_name" content="Juan Felipe" />
    <meta property="profile:last_name" content="Rodríguez Galindo" />
    <meta property="profile:username" content={PROFILE.handle} />
    <meta property="og:title" content={`${PROFILE.name} — ${PROFILE.title}`} />
    <meta property="og:description" content={PROFILE.tagline} />
    <meta property="og:url" content="https://juferoga.pro" />
    <meta property="og:image" content="https://juferoga.pro/og.png" />
    <meta property="og:image:alt" content={`Tarjeta de presentación de ${PROFILE.name} con estética de terminal`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="juferoga.pro" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${PROFILE.name} — ${PROFILE.title}`} />
    <meta name="twitter:description" content={PROFILE.tagline} />
    <meta name="twitter:image" content="https://juferoga.pro/og.png" />
    <meta name="twitter:image:alt" content={`Tarjeta de presentación de ${PROFILE.name} con estética de terminal`} />

    <meta name="theme-color" content="#0a0e0a" />
    <meta name="color-scheme" content="dark" />
    <meta name="keywords" content="Juan Felipe Rodríguez Galindo, juferoga, Cloud Developer, Ingeniero de Sistemas, AWS, Angular, GNU/Linux, portafolio, Bogotá" />
    <link rel="canonical" href="https://juferoga.pro" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="juferoga.pro — blog" href="/rss.xml" />

    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <noscript>
      <style>
        /* Sin JavaScript la terminal no funciona: se muestra la versión visual (SSR). */
        .terminal, .hint, #bg-canvas, #matrix-canvas, .crt-overlay, .scanlines, .flicker { display: none !important; }
        .gui { display: block !important; position: relative; z-index: 10; }
        html, body { overflow-y: auto !important; height: auto !important; }
        .gui-back { display: none !important; }
      </style>
    </noscript>
  </head>
  <body>
    <script is:inline id="gh-stats-build" type="application/json" set:html={JSON.stringify(ghStats).replace(/</g, "\\u003c")}></script>
    <script is:inline id="blog-posts-build" type="application/json" set:html={JSON.stringify(blogPosts).replace(/</g, "\\u003c")}></script>
    <Terminal />
    <GuiMode stats={ghStats} />
    {import.meta.env.PROD && (
      <script is:inline data-goatcounter={GOATCOUNTER} async src="https://gc.zgo.at/count.js"></script>
    )}
  </body>
</html>
