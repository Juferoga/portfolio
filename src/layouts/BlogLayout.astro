---
import "../styles/global.css";
import { PROFILE } from "../data/profile";

interface Props {
  title: string;
  description: string;
  /** Ruta canónica, p.ej. "/blog" o "/blog/hola-mundo" */
  path: string;
  /** Fecha de publicación (solo posts) — activa metadatos de artículo */
  publishedDate?: Date;
}

const { title, description, path, publishedDate } = Astro.props;
const canonical = `https://juferoga.pro${path}`;
const fullTitle = title === "blog" ? "blog · juferoga.pro" : `${title} · blog · juferoga.pro`;

const jsonLd = publishedDate
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description,
      datePublished: publishedDate.toISOString(),
      inLanguage: "es",
      url: canonical,
      author: { "@type": "Person", "@id": "https://juferoga.pro/#person", name: PROFILE.name, url: "https://juferoga.pro" },
    }
  : {
      "@context": "https://schema.org",
      "@type": "Blog",
      name: "juferoga.pro — blog",
      description,
      inLanguage: "es",
      url: canonical,
      author: { "@type": "Person", "@id": "https://juferoga.pro/#person", name: PROFILE.name, url: "https://juferoga.pro" },
    };
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={PROFILE.name} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content={publishedDate ? "article" : "website"} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://juferoga.pro/og.png" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="juferoga.pro" />
    {publishedDate && <meta property="article:published_time" content={publishedDate.toISOString()} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://juferoga.pro/og.png" />

    <meta name="theme-color" content="#0a0e0a" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="juferoga.pro — blog" href="/rss.xml" />

    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="blog-page">
    <div class="crt-overlay" aria-hidden="true"></div>
    <div class="scanlines" aria-hidden="true"></div>

    <header class="blog-topbar">
      <nav class="blog-nav" aria-label="Navegación del blog">
        <a href="/" class="blog-brand"><span class="prompt-user">{PROFILE.handle}</span><span class="prompt-at">@</span><span class="prompt-host">portfolio</span><span class="prompt-sep">:</span><span class="prompt-path">~/blog</span></a>
        <span class="blog-links">
          <a href="/">~ inicio</a>
          <a href="/blog">blog</a>
          <a href="/rss.xml">rss</a>
        </span>
      </nav>
    </header>

    <main class="blog-main">
      <slot />
    </main>

    <footer class="blog-footer">
      <span>“{PROFILE.tagline}”</span>
      <span class="dim">© {new Date().getFullYear()} {PROFILE.name} · <a href="/rss.xml">RSS</a></span>
    </footer>

    {import.meta.env.PROD && (
      <script is:inline data-goatcounter="https://juferoga.goatcounter.com/count" async src="https://gc.zgo.at/count.js"></script>
    )}
  </body>
</html>

<style is:global>
  /* Las páginas del blog son documentos con scroll normal (el resto del sitio lo bloquea) */
  html:has(.blog-page), body.blog-page {
    overflow-y: auto;
    height: auto;
    min-height: 100%;
    scrollbar-width: thin;
    scrollbar-color: var(--fg-dim) transparent;
  }

  .blog-topbar {
    position: sticky; top: 0; z-index: 60;
    border-bottom: 1px solid var(--fg-dim);
    background: rgba(5, 10, 6, 0.9);
    backdrop-filter: blur(6px);
  }
  .blog-nav {
    max-width: 760px; margin: 0 auto; padding: 12px 18px;
    display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap;
  }
  .blog-brand { text-decoration: none; font-weight: 700; }
  .blog-links { display: flex; gap: 16px; }
  .blog-nav a { color: var(--link); text-decoration: none; border-bottom: 1px dotted transparent; }
  .blog-nav a:hover { color: var(--fg-bright); border-bottom-color: var(--fg-bright); text-shadow: 0 0 8px var(--glow); }

  .blog-main { max-width: 760px; margin: 0 auto; padding: 36px 18px 20px; position: relative; z-index: 10; }

  .blog-footer {
    max-width: 760px; margin: 0 auto; padding: 20px 18px 40px;
    display: flex; justify-content: space-between; gap: 12px; flex-wrap: wrap;
    border-top: 1px solid var(--fg-dim); color: var(--fg-bright); font-style: italic; font-size: 14px;
  }
  .blog-footer .dim { color: var(--fg-dim); font-style: normal; }
  .blog-footer a { color: var(--link); }

  /* Tipografía de artículos (contenido Markdown) */
  .blog-prose { line-height: 1.75; }
  .blog-prose h2 { color: var(--accent); margin: 28px 0 10px; font-size: 21px; border-bottom: 1px dashed var(--fg-dim); padding-bottom: 6px; }
  .blog-prose h3 { color: var(--fg-bright); margin: 22px 0 8px; font-size: 17px; }
  .blog-prose p { margin: 12px 0; color: var(--fg); }
  .blog-prose a { color: var(--link); text-decoration: none; border-bottom: 1px dotted var(--link); }
  .blog-prose a:hover { color: var(--fg-bright); text-shadow: 0 0 8px var(--glow); }
  .blog-prose strong { color: var(--fg-bright); }
  .blog-prose em { color: var(--fg-bright); }
  .blog-prose ul, .blog-prose ol { margin: 12px 0; padding-left: 26px; }
  .blog-prose li { margin: 6px 0; }
  .blog-prose blockquote { border-left: 3px solid var(--accent); padding: 4px 0 4px 16px; margin: 14px 0; color: var(--fg-bright); font-style: italic; }
  .blog-prose code { background: rgba(255,255,255,0.07); border: 1px solid var(--fg-dim); border-radius: 4px; padding: 1px 6px; font-size: 0.92em; }
  .blog-prose pre { margin: 14px 0; padding: 14px 16px; border: 1px solid var(--fg-dim); border-radius: 8px; overflow-x: auto; }
  .blog-prose pre code { background: none; border: none; padding: 0; }
  .blog-prose img { max-width: 100%; border-radius: 8px; border: 1px solid var(--fg-dim); }
  .blog-prose hr { border: none; border-top: 1px dashed var(--fg-dim); margin: 24px 0; }
</style>
