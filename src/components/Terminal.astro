             <figure class="photo-slot photo-wide"><img class="lb" data-gallery="me" data-caption="SLUD XXII — charla &quot;El futuro de Linux&quot; (ex-Director del GLUD)" src="/assets/photos/glud-talk.jpg" alt="charla SLUD" onerror="this.parentElement.innerHTML='[ conferencia ]'"></figure>
           </div>`
        );
