  let matrixRAF = 0;
  function startMatrix() {
    const ctx = canvas.getContext("2d")!;
    canvas.classList.add("active");
    const resize = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    };
    resize();
    const fontSize = 16;
    const cols = Math.floor(canvas.width / fontSize);
    const drops = new Array(cols).fill(1);
    const chars = "ｱｲｳｴｵｶｷｸ01アカサタナ<>{}[]#$%&/=jufERoga";
    const color = getComputedStyle(document.body).getPropertyValue("--fg") || "#33ff66";

    const draw = () => {
      ctx.fillStyle = "rgba(0,0,0,0.06)";
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = color.trim() || "#33ff66";
      ctx.font = fontSize + "px monospace";
      for (let i = 0; i < drops.length; i++) {
        const ch = chars[Math.floor(Math.random() * chars.length)];
        ctx.fillText(ch, i * fontSize, drops[i] * fontSize);
        if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
        drops[i]++;
      }
      matrixRAF = requestAnimationFrame(draw);
    };
    draw();

    const stop = () => {
      cancelAnimationFrame(matrixRAF);
      canvas.classList.remove("active");
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      window.removeEventListener("keydown", onKey);
      window.removeEventListener("click", onClick);
      print("← saliste de la Matrix. (presionaste una tecla)", "dim");
      cmdInput.focus();
    };
    const onKey = () => stop();
    const onClick = () => stop();
    setTimeout(() => {
      window.addEventListener("keydown", onKey);
      window.addEventListener("click", onClick);
    }, 300);
    window.addEventListener("resize", resize);
  }

  
  
  let pongActive = false;
  function startPong() {
    if (pongActive) return;
    pongActive = true;
    cmdInput.blur(); // que el input no capture las teclas del juego

    const cvs = document.createElement("canvas");
    cvs.id = "game-canvas";
    document.body.appendChild(cvs);
    const ctx = cvs.getContext("2d")!;
    const css = getComputedStyle(document.body);
    const FG = (css.getPropertyValue("--fg") || "#33ff66").trim();
    const ACC = (css.getPropertyValue("--accent") || "#00ffaa").trim();
    const BR = (css.getPropertyValue("--fg-bright") || "#aaffbb").trim();
    const WARN = (css.getPropertyValue("--warn") || "#ffcc33").trim();

    let W = 0, H = 0;
    const resize = () => { W = cvs.width = window.innerWidth; H = cvs.height = window.innerHeight; };
    resize();
    window.addEventListener("resize", resize);

    const PADW = 12, PADH = 90, MARGIN = 40;
    const player = { y: H / 2 - PADH / 2, score: 0 };
    const cpu = { y: H / 2 - PADH / 2, score: 0 };
    const WIN = 5;

    const wall = { w: 16, h: 120, y: H / 2 - 60, vy: 3 };

    const trail: { x: number; y: number }[] = [];
    const ball = { x: 0, y: 0, vx: 0, vy: 0, r: 9 };
    function resetBall(dir: number) {
      ball.x = W / 2; ball.y = H / 2;
      const ang = (Math.random() * 0.6 - 0.3);
      const sp = 6;
      ball.vx = dir * sp * Math.cos(ang);
      ball.vy = sp * Math.sin(ang);
      trail.length = 0;
    }
    resetBall(Math.random() < 0.5 ? -1 : 1);

    let upPressed = false, downPressed = false, over = false, winner = "";

    const onMove = (e: MouseEvent) => { player.y = e.clientY - PADH / 2; };
    const onKeyDown = (e: KeyboardEvent) => {
      if (e.key === "Escape" || e.key.toLowerCase() === "q") { stop(); return; }
      if (e.key === "ArrowUp" || e.key.toLowerCase() === "w") { upPressed = true; e.preventDefault(); }
      if (e.key === "ArrowDown" || e.key.toLowerCase() === "s") { downPressed = true; e.preventDefault(); }
      if (over && (e.key === "Enter" || e.key === " ")) restart();
    };
    const onKeyUp = (e: KeyboardEvent) => {
      if (e.key === "ArrowUp" || e.key.toLowerCase() === "w") upPressed = false;
      if (e.key === "ArrowDown" || e.key.toLowerCase() === "s") downPressed = false;
    };
    window.addEventListener("mousemove", onMove);
    window.addEventListener("keydown", onKeyDown);
    window.addEventListener("keyup", onKeyUp);

    function restart() {
      player.score = 0; cpu.score = 0; over = false; winner = "";
      resetBall(Math.random() < 0.5 ? -1 : 1);
    }

    const clamp = (v: number, lo: number, hi: number) => Math.max(lo, Math.min(hi, v));

    let raf = 0;
    function loop() {
      if (!over) {
        if (upPressed) player.y -= 8;
        if (downPressed) player.y += 8;
        player.y = clamp(player.y, 0, H - PADH);

        const target = ball.y - PADH / 2;
        cpu.y += clamp(target - cpu.y, -6, 6);
        cpu.y = clamp(cpu.y, 0, H - PADH);

        wall.y += wall.vy;
        if (wall.y <= 0 || wall.y + wall.h >= H) wall.vy *= -1;

        ball.x += ball.vx; ball.y += ball.vy;
        trail.push({ x: ball.x, y: ball.y });
        if (trail.length > 14) trail.shift();

        const VMAX = 13;
        ball.vy = clamp(ball.vy, -VMAX, VMAX);
        ball.vx = clamp(ball.vx, -VMAX, VMAX);

        if (ball.y - ball.r <= 0) { ball.y = ball.r; ball.vy = Math.abs(ball.vy); beep(420, 12); }
        else if (ball.y + ball.r >= H) { ball.y = H - ball.r; ball.vy = -Math.abs(ball.vy); beep(420, 12); }

        if (ball.x - ball.r <= MARGIN + PADW && ball.x > MARGIN &&
            ball.y >= player.y && ball.y <= player.y + PADH && ball.vx < 0) {
          ball.vx = Math.abs(ball.vx) * 1.06;
          ball.vy += (ball.y - (player.y + PADH / 2)) * 0.05;
          ball.x = MARGIN + PADW + ball.r; beep(660, 14);
        }
        if (ball.x + ball.r >= W - MARGIN - PADW && ball.x < W - MARGIN &&
            ball.y >= cpu.y && ball.y <= cpu.y + PADH && ball.vx > 0) {
          ball.vx = -Math.abs(ball.vx) * 1.06;
          ball.vy += (ball.y - (cpu.y + PADH / 2)) * 0.05;
          ball.x = W - MARGIN - PADW - ball.r; beep(600, 14);
        }
        const wx = W / 2 - wall.w / 2;
        if (ball.x + ball.r >= wx && ball.x - ball.r <= wx + wall.w &&
            ball.y + ball.r >= wall.y && ball.y - ball.r <= wall.y + wall.h) {
          if (ball.vx > 0) { ball.vx = -Math.abs(ball.vx); ball.x = wx - ball.r; }
          else { ball.vx = Math.abs(ball.vx); ball.x = wx + wall.w + ball.r; }
          beep(300, 20);
        }

        if (ball.x < -20) { cpu.score++; check(1); }
        else if (ball.x > W + 20) { player.score++; check(-1); }
      }

      ctx.fillStyle = "rgba(0,0,0,0.78)";
      ctx.fillRect(0, 0, W, H);
      ctx.strokeStyle = "rgba(255,255,255,0.12)";
      ctx.setLineDash([8, 14]); ctx.beginPath();
      ctx.moveTo(W / 2, 0); ctx.lineTo(W / 2, H); ctx.stroke(); ctx.setLineDash([]);
      for (let i = 0; i < trail.length; i++) {
        ctx.globalAlpha = (i / trail.length) * 0.5;
        ctx.fillStyle = ACC;
        ctx.fillRect(trail[i].x - 4, trail[i].y - 4, 8, 8);
      }
      ctx.globalAlpha = 1;
      ctx.fillStyle = BR;
      ctx.fillRect(MARGIN, player.y, PADW, PADH);
      ctx.fillRect(W - MARGIN - PADW, cpu.y, PADW, PADH);
      ctx.fillStyle = WARN;
      ctx.fillRect(W / 2 - wall.w / 2, wall.y, wall.w, wall.h);
      ctx.fillStyle = FG;
      ctx.shadowColor = ACC; ctx.shadowBlur = 16;
      ctx.fillRect(ball.x - ball.r, ball.y - ball.r, ball.r * 2, ball.r * 2);
      ctx.shadowBlur = 0;
      ctx.fillStyle = BR;
      ctx.font = "bold 42px JetBrains Mono, monospace";
      ctx.textAlign = "center";
      ctx.fillText(String(player.score), W / 2 - 80, 60);
      ctx.fillText(String(cpu.score), W / 2 + 80, 60);
      ctx.font = "14px JetBrains Mono, monospace";
      ctx.fillStyle = "rgba(255,255,255,0.5)";
      ctx.fillText("TÚ", W / 2 - 80, 82);
      ctx.fillText("CPU", W / 2 + 80, 82);
      ctx.fillText("W/S o ↑/↓ · ratón · ESC/Q para salir · ¡cuidado con el muro amarillo!", W / 2, H - 24);

      if (over) {
        ctx.fillStyle = "rgba(0,0,0,0.6)"; ctx.fillRect(0, H / 2 - 70, W, 140);
        ctx.fillStyle = winner === "player" ? ACC : WARN;
        ctx.font = "bold 40px JetBrains Mono, monospace";
        ctx.fillText(winner === "player" ? "🏆 ¡GANASTE!" : "💀 GANÓ LA CPU", W / 2, H / 2);
        ctx.fillStyle = BR; ctx.font = "16px JetBrains Mono, monospace";
        ctx.fillText("Enter para jugar de nuevo · ESC para salir", W / 2, H / 2 + 34);
      }

      raf = requestAnimationFrame(loop);
    }

    function check(dir: number) {
      beep(dir > 0 ? 220 : 880, 60);
      if (player.score >= WIN) { over = true; winner = "player"; }
      else if (cpu.score >= WIN) { over = true; winner = "cpu"; }
      else resetBall(dir);
    }

    function stop() {
      cancelAnimationFrame(raf);
      window.removeEventListener("mousemove", onMove);
      window.removeEventListener("keydown", onKeyDown);
      window.removeEventListener("keyup", onKeyUp);
      window.removeEventListener("resize", resize);
      cvs.remove();
      pongActive = false;
      const res = player.score > cpu.score
        ? `🏆 saliste ganando ${player.score}-${cpu.score}. ¡crack!`
        : `partida cerrada (${player.score}-${cpu.score}). ¡revancha cuando quieras!`;
      print("← saliste de PONG. " + res, "dim");
      cmdInput.focus();
    }

    loop();
  }

  
  
  const KONAMI = [
    "ArrowUp", "ArrowUp", "ArrowDown", "ArrowDown",
    "ArrowLeft", "ArrowRight", "ArrowLeft", "ArrowRight", "b", "a",
  ];
  let konamiIdx = 0;
  window.addEventListener("keydown", (e) => {
    if (e.key === KONAMI[konamiIdx] || e.key.toLowerCase() === KONAMI[konamiIdx]) {
      konamiIdx++;
      if (konamiIdx === KONAMI.length) {
        konamiIdx = 0;
        print("🎮 KONAMI CODE ACTIVADO — modo dios desbloqueado 🚀", "warn");
        print("Gracias por explorar. Eres de los curiosos, como yo. 🤝", "accent");
        document.body.style.animation = "none";
        startMatrix();
      }
    } else {
      konamiIdx = 0;
    }
  });

  
  
  const bgCanvas = $("#bg-canvas") as HTMLCanvasElement;
  const bx = bgCanvas.getContext("2d")!;
  const reduceMotion = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches;
  let bw = 0, bh = 0;
  const bgResize = () => { bw = bgCanvas.width = window.innerWidth; bh = bgCanvas.height = window.innerHeight; };
  bgResize();
  window.addEventListener("resize", bgResize);

  type Wire = { pts: { x: number; y: number }[]; age: number; grow: number; hold: number; fade: number };
  const wires: Wire[] = [];
  const themeColor = () =>
    (getComputedStyle(document.body).getPropertyValue("--accent") || "#00ffaa").trim();

  function newWire(): Wire {
    const edge = Math.floor(Math.random() * 4);
    let x: number, y: number, dir: number;
    if (edge === 0) { x = Math.random() * bw; y = 0; dir = 2; }        // arriba → baja
    else if (edge === 1) { x = Math.random() * bw; y = bh; dir = 3; }  // abajo → sube
    else if (edge === 2) { x = 0; y = Math.random() * bh; dir = 0; }   // izq → derecha
    else { x = bw; y = Math.random() * bh; dir = 1; }                  // der → izquierda
    const pts = [{ x, y }];
    const segs = 4 + Math.floor(Math.random() * 5);
    for (let i = 0; i < segs; i++) {
      const len = 40 + Math.random() * 160;
      if (dir === 0) x += len; else if (dir === 1) x -= len;
      else if (dir === 2) y += len; else y -= len;
      pts.push({ x, y });
      dir = dir < 2 ? 2 + (Math.random() < 0.5 ? 0 : 1) : (Math.random() < 0.5 ? 0 : 1); // giro 90°
    }
    return { pts, age: 0, grow: 60 + Math.random() * 60, hold: 80 + Math.random() * 140, fade: 60 + Math.random() * 60 };
  }

  function drawWire(w: Wire, color: string, alpha: number) {
    const pts = w.pts;
    let L = 0;
    for (let i = 1; i < pts.length; i++) L += Math.abs(pts[i].x - pts[i - 1].x) + Math.abs(pts[i].y - pts[i - 1].y);
    const f = Math.min(1, w.age / w.grow);
    const target = L * f;
    bx.strokeStyle = color; bx.globalAlpha = alpha; bx.lineWidth = 1.5;
    bx.shadowColor = color; bx.shadowBlur = 6; // glow para que se aprecien
    bx.beginPath(); bx.moveTo(pts[0].x, pts[0].y);
    let acc = 0, hx = pts[0].x, hy = pts[0].y;
    for (let i = 1; i < pts.length; i++) {
      const seg = Math.abs(pts[i].x - pts[i - 1].x) + Math.abs(pts[i].y - pts[i - 1].y);
      if (acc + seg <= target) { bx.lineTo(pts[i].x, pts[i].y); acc += seg; hx = pts[i].x; hy = pts[i].y; }
      else { const r = seg ? (target - acc) / seg : 0; hx = pts[i - 1].x + (pts[i].x - pts[i - 1].x) * r; hy = pts[i - 1].y + (pts[i].y - pts[i - 1].y) * r; bx.lineTo(hx, hy); break; }
    }
    bx.stroke();
    bx.globalAlpha = alpha * 1.6;
    for (let i = 0; i < pts.length; i++) {
      const d = (pts.slice(0, i + 1).reduce((s, p, j) => j ? s + Math.abs(p.x - pts[j - 1].x) + Math.abs(p.y - pts[j - 1].y) : 0, 0));
      if (d <= target) bx.fillRect(pts[i].x - 1.5, pts[i].y - 1.5, 3, 3);
    }
    bx.fillRect(hx - 1.5, hy - 1.5, 3, 3);
    bx.globalAlpha = 1; bx.shadowBlur = 0;
  }

  let bgRAF = 0;
  function bgLoop() {
    bx.clearRect(0, 0, bw, bh);
    const color = themeColor();
    for (let i = wires.length - 1; i >= 0; i--) {
      const w = wires[i]; w.age++;
      const total = w.grow + w.hold + w.fade;
      const MAXA = 0.26;
      let a = MAXA;
      if (w.age < w.grow) a = MAXA * (w.age / w.grow); // aparición suave
      else if (w.age > w.grow + w.hold) a = MAXA * (1 - (w.age - w.grow - w.hold) / w.fade);
      if (w.age >= total) { wires.splice(i, 1); continue; }
      drawWire(w, color, Math.max(0, a));
    }
    if (wires.length < 26 && Math.random() < 0.14) wires.push(newWire());
    if (!document.body.classList.contains("gui-active")) {
      const tr = terminalEl.getBoundingClientRect();
      if (tr.width && tr.height) bx.clearRect(tr.left, tr.top, tr.width, tr.height);
    }
    bgRAF = requestAnimationFrame(bgLoop);
  }
  if (!reduceMotion) bgLoop();

  
  
  const lb = $("#lightbox") as HTMLElement;
  const lbImg = $("#lb-img") as HTMLImageElement;
  const lbCap = $("#lb-caption") as HTMLElement;
  const lbCount = $("#lb-count") as HTMLElement;
  let lbItems: { src: string; caption: string }[] = [];
  let lbIdx = 0;

  function lbShow() {
    const it = lbItems[lbIdx];
    if (!it) return;
    lbImg.src = it.src; lbImg.alt = it.caption;
    lbCap.textContent = it.caption;
    const multi = lbItems.length > 1;
    lbCount.textContent = multi ? `${lbIdx + 1} / ${lbItems.length}` : "";
    lb.classList.toggle("multi", multi);
  }
  function openLightbox(items: { src: string; caption: string }[], idx = 0) {
    if (!items.length) return;
    lbItems = items; lbIdx = idx;
    lbShow();
    lb.classList.add("open");
    lb.setAttribute("aria-hidden", "false");
    beep(620, 22);
  }
  function lbClose() { lb.classList.remove("open"); lb.setAttribute("aria-hidden", "true"); cmdInput.focus(); }
  function lbNav(d: number) { if (lbItems.length < 2) return; lbIdx = (lbIdx + d + lbItems.length) % lbItems.length; lbShow(); beep(660, 14); }

  lb.addEventListener("click", (e) => {
    const tgt = e.target as HTMLElement;
    if (tgt.closest("[data-lb-close]")) lbClose();
    else if (tgt.closest("[data-lb-prev]")) lbNav(-1);
    else if (tgt.closest("[data-lb-next]")) lbNav(1);
  });
  window.addEventListener("keydown", (e) => {
    if (!lb.classList.contains("open")) return;
    if (e.key === "Escape") lbClose();
    else if (e.key === "ArrowLeft") lbNav(-1);
    else if (e.key === "ArrowRight") lbNav(1);
  });
  document.addEventListener("click", (e) => {
    const img = (e.target as HTMLElement).closest("img.lb") as HTMLImageElement | null;
    if (!img) return;
    e.stopPropagation();
    const gal = img.dataset.gallery;
    const group = gal
      ? Array.from(document.querySelectorAll<HTMLImageElement>(`img.lb[data-gallery="${gal}"]`))
      : [img];
    const items = group.map((g) => ({
      src: g.currentSrc || g.getAttribute("src") || "",
      caption: g.dataset.caption || g.alt || "",
    }));
    openLightbox(items, Math.max(0, group.indexOf(img)));
  }, true);

  
  
