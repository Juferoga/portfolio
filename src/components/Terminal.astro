        print(t().hNow, "dim");
        P.now.forEach((l) => print(esc(l)));
        print("");
        print(t().nowSrc, "dim");
      },
    },

    recommendations: {
      desc: "Lo que dicen de mí",
      run: () => {
        print(t().hRecs, "dim");
        for (const tt of P.testimonials) {
          printHTML(
            `<div class="entry">
               <div class="desc">“${esc(tt.quote)}”</div>
               <div class="meta">— ${esc(tt.name)}</div>
               <div class="period">${esc(tt.role)}</div>
             </div>`
          );
        }
      },
    },

    stats: {
      desc: "Stats de GitHub",
      run: async () => {
        print(t().stats.head, "dim");
        const cache = readStatsCache();
        const fresh = !!cache && Date.now() - cache.at < STATS_TTL;
        const initial: GHStats | null = fresh ? cache!.data : (buildStats() || (cache ? cache.data : null));
        const src = fresh ? t().stats.srcCache : t().stats.srcBuild;
        const block = printHTML(
          initial ? renderStatsHTML(initial, src) : `<div class="gh-stats"><div class="dim">${t().stats.loading}</div></div>`
        );
        scrollDown();
        if (!fresh) {
          const live = await fetchLiveStats();
          if (live) { writeStatsCache(live); block.innerHTML = renderStatsHTML(live, t().stats.srcLive); }
          else if (!initial) {
            block.innerHTML = `<div class="dim">${t().stats.unavailable} ${link(P.contact.github, "GitHub")}.</div>`;
          }
          scrollDown();
        }
      },
    },

    skills: {
      desc: "Tecnologías",
      run: () => {
        print(t().hStack, "dim");
        for (const [cat, items] of Object.entries(P.skills)) {
          let html = `<div class="skillset"><span class="cat">${cat}</span><br>`;
          html += items.map((s) => `<span class="badge">${esc(s)}</span>`).join("");
          html += "</div>";
          printHTML(html);
        }
      },
    },

    experience: {
      desc: "Experiencia",
      run: () => {
        print(t().hExp, "dim");
        for (const e of P.experience) {
          let html = `<div class="entry">
            <div class="role">${esc(e.role)}</div>
            <div class="meta">${esc(e.company)}</div>
            <div class="period">${esc(e.period)}</div>`;
          html += e.lines.map((l) => `<div class="desc">${esc(l)}</div>`).join("");
          html += "</div>";
          printHTML(html);
        }
      },
    },

    education: {
      desc: "Educación",
      run: () => {
        print(t().hEdu, "dim");
        for (const e of P.education) {
          printHTML(`<div class="entry">
            <div class="role">${esc(e.degree)}</div>
