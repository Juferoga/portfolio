  const t = () => UI[lang];

  const link = (url: string, label?: string) =>
    `<a href="${url}" target="_blank" rel="noopener">${label ?? url}</a>`;

  
  
  interface GHStats {
    login: string; name: string; followers: number; publicRepos: number;
    totalStars: number; createdYear: number;
    topLanguages: { name: string; count: number }[];
    topRepo: { name: string; stars: number; url: string } | null;
    fetchedAt: string;
  }
  const GH_USER = "Juferoga";
  const STATS_TTL = 1000 * 60 * 60 * 6; // 6 h de caché en el cliente

  function buildStats(): GHStats | null {
    try { return JSON.parse(document.getElementById("gh-stats-build")?.textContent || "null"); }
    catch { return null; }
  }
  function readStatsCache(): { at: number; data: GHStats } | null {
    try { const r = localStorage.getItem("ghStats"); const o = r ? JSON.parse(r) : null; return o && o.data ? o : null; }
    catch { return null; }
  }
  function writeStatsCache(data: GHStats) {
    try { localStorage.setItem("ghStats", JSON.stringify({ at: Date.now(), data })); } catch {}
  }

  async function fetchLiveStats(): Promise<GHStats | null> {
    try {
      const headers = { Accept: "application/vnd.github+json" };
      const [uRes, rRes] = await Promise.all([
        fetch(`https://api.github.com/users/${GH_USER}`, { headers }),
        fetch(`https://api.github.com/users/${GH_USER}/repos?per_page=100&type=owner&sort=pushed`, { headers }),
      ]);
      if (!uRes.ok || !rRes.ok) return null;
      const u: any = await uRes.json();
      const repos: any[] = await rRes.json();
      if (!Array.isArray(repos)) return null;
      const own = repos.filter((r) => !r.fork);
      const totalStars = own.reduce((s, r) => s + (r.stargazers_count || 0), 0);
      const lc: Record<string, number> = {};
      for (const r of own) if (r.language) lc[r.language] = (lc[r.language] || 0) + 1;
      const topLanguages = Object.entries(lc).sort((a, b) => b[1] - a[1]).slice(0, 6).map(([name, count]) => ({ name, count }));
      const top = own.slice().sort((a, b) => (b.stargazers_count || 0) - (a.stargazers_count || 0))[0];
      return {
        login: u.login, name: u.name || u.login, followers: u.followers || 0,
        publicRepos: u.public_repos || 0, totalStars, createdYear: new Date(u.created_at).getFullYear(),
        topLanguages, topRepo: top ? { name: top.name, stars: top.stargazers_count || 0, url: top.html_url } : null,
        fetchedAt: new Date().toISOString(),
      };
    } catch { return null; }
  }

  function relTime(iso: string): string {
    try {
      const diff = Date.now() - new Date(iso).getTime();
      const m = Math.floor(diff / 60000), h = Math.floor(m / 60), d = Math.floor(h / 24);
      if (d > 0) return lang === "en" ? `${d}d ago` : `hace ${d}d`;
      if (h > 0) return lang === "en" ? `${h}h ago` : `hace ${h}h`;
      if (m > 0) return lang === "en" ? `${m}m ago` : `hace ${m}m`;
      return lang === "en" ? "just now" : "recién";
    } catch { return ""; }
  }

  function renderStatsHTML(s: GHStats, src: string): string {
    const S = t().stats;
    const maxL = Math.max(1, ...s.topLanguages.map((l) => l.count));
    const langs = s.topLanguages.map((l) =>
      `<div class="gh-lang"><span class="gh-lang-name">${esc(l.name)}</span><span class="gh-bar"><span style="width:${Math.round((l.count / maxL) * 100)}%"></span></span><span class="gh-lang-n">${l.count}</span></div>`
    ).join("");
    const topRepo = s.topRepo ? `${link(s.topRepo.url, esc(s.topRepo.name))} <span class="dim">★ ${s.topRepo.stars}</span>` : "—";
    return `<div class="gh-stats">
      <div class="gh-grid">
        <div class="gh-stat"><span class="gh-num">${s.publicRepos}</span><span class="gh-lbl">${S.repos}</span></div>
        <div class="gh-stat"><span class="gh-num">★ ${s.totalStars}</span><span class="gh-lbl">${S.stars}</span></div>
        <div class="gh-stat"><span class="gh-num">${s.followers}</span><span class="gh-lbl">${S.followers}</span></div>
        <div class="gh-stat"><span class="gh-num">${s.createdYear}</span><span class="gh-lbl">${S.since}</span></div>
      </div>
      <div class="gh-langs"><div class="gh-sub">${S.langs}</div>${langs}</div>
      <div class="gh-toprepo"><span class="gh-sub">${S.topRepo}:</span> ${topRepo}</div>
      <div class="gh-src">${S.source(src, relTime(s.fetchedAt))}</div>
    </div>`;
  }

  const COMMANDS: Record<
