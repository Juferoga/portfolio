           onerror="this.parentElement.innerHTML='[ foto ]'"></div>
       </div>`
    );
    await bootSleep(150);
    await typeLine(`${P.name} — ${P.title}`, "bright", 10);
    printHTML(`<div class="quote">"${P.tagline}"</div>`);
    print("");
    await typeLine(t().welcome, "accent", 8);
    print("");
    printWelcomeChooser();
    print("");

    bootingActive = false;
    window.removeEventListener("keydown", skipper);
    window.removeEventListener("click", skipper);

    inputLine.style.display = "flex";
    syncFake(); // pinta el cursor con su contenido inicial (alto/ancho correctos)
    cmdInput.focus();
    scrollDown();
  }

  boot();
</script>
