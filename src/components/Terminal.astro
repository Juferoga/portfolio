      <span class="dot yellow" id="dot-yellow" title="Minimizar"></span>
      <span class="dot green" id="dot-green" title="Maximizar"></span>
    </div>
    <div class="titlebar-text" id="titlebar-text">juferoga@portfolio: ~</div>
    <div class="titlebar-actions">
      <button id="gui-btn" class="tb-btn tb-btn-wide" title="Cambiar a versión visual">🖥 visual</button>
      <button id="lang-btn" class="tb-btn" title="Idioma ES/EN">🌐 ES</button>
      <button id="sound-btn" class="tb-btn" title="Sonido de tecleo (on/off)">🔊</button>
