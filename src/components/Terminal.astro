    "fotos": "photo",
    "logros": "achievements",
    "redes": "social",
    "audio": "sound",
    "recomendaciones": "recommendations",
    "github": "stats",
    "gh": "stats",
    "estadisticas": "stats",
    "idioma": "lang",
    "language": "lang",
    "testimonials": "recommendations",
    "testimonios": "recommendations",
    "reviews": "recommendations",
    "game": "pong",
    "juego": "pong",
    "play": "pong",
  };

  
  
  const COMBO_TIERS: Record<number, string> = {
    1: "🥉 Primer Combo — descubriste el ritual clear → ls",
    10: "🥈 Manos Rápidas — clear → ls ×10",
    25: "🥇 Hacker en Práctica — clear → ls ×25",
    50: "🏆 Maestro del Terminal — clear → ls ×50",
    100: "👑 LEYENDA VIVIENTE — clear → ls ×100",
  };

  let lastCmdKey = "";

  function getCombo(): number {
    try { return parseInt(localStorage.getItem("comboClearLs") || "0", 10) || 0; } catch { return 0; }
  }
  function setCombo(n: number) {
    try { localStorage.setItem("comboClearLs", String(n)); } catch {}
  }

  function unlockAchievement(text: string, count: number) {
    printHTML(
      `<div class="achievement">
         <div class="ach-title">🎖️ LOGRO DESBLOQUEADO</div>
         <div class="ach-body">${text}</div>
         <div class="ach-sub">combos totales: ${count}</div>
       </div>`
    );
  }

  function registerComboStep(key: string) {
    if (key === "ls" && lastCmdKey === "clear") {
      const n = getCombo() + 1;
      setCombo(n);
      if (COMBO_TIERS[n]) unlockAchievement(COMBO_TIERS[n], n);
    }
  }

  
  
  async function execute(raw: string) {
    const trimmed = raw.trim();
    const echo = document.createElement("div");
    echo.className = "line cmd-echo";
    echo.innerHTML =
      `<span class="prompt-user">juferoga</span><span class="prompt-at">@</span><span class="prompt-host">portfolio</span><span class="prompt-sep">:</span><span class="prompt-path">~</span><span class="prompt-dollar">$</span> ` +
      esc(trimmed);
    output.appendChild(echo);

    if (!trimmed) {
      scrollDown();
      return;
    }

    const [name, ...args] = trimmed.split(/\s+/);
    const key = ALIASES[name.toLowerCase()] ?? name.toLowerCase();
    const cmd = COMMANDS[key];

    spacer();
    if (cmd) {
      await cmd.run(args);
      registerComboStep(key);
      lastCmdKey = key;
    } else {
      print(t().notFound(esc(name)), "error");
      const candidates = [...PUBLIC_CMDS, ...Object.keys(ALIASES)];
      let best = "", bestD = Infinity;
      for (const c of candidates) {
        const d = levenshtein(key, c);
        if (d < bestD) { bestD = d; best = c; }
      }
      if (best && bestD <= 3) {
        const sugg = ALIASES[best] ?? best;
        print(t().didYouMean(esc(sugg)), "warn");
      }
      print(t().seeHelp, "dim");
      lastCmdKey = ""; // un comando inválido rompe el combo
    }
    spacer();
    scrollDown();
  }

  
  
  const history: string[] = [];
  let histIdx = -1;

  const PUBLIC_CMDS = Object.keys(COMMANDS).filter((k) => !COMMANDS[k].hidden);

  function syncFake() {
    const v = cmdInput.value;
    const pos = cmdInput.selectionStart ?? v.length;
    fiBefore.textContent = v.slice(0, pos);
    const ch = v.slice(pos, pos + 1);
    cursorEl.textContent = ch === "" ? " " : ch;
    fiAfter.textContent = v.slice(pos + 1);
    const gh = pos === v.length ? ghostSuggestion(v) : "";
    if (gh) {
      cursorEl.textContent = gh[0];
      ghostEl.textContent = gh.slice(1);
    } else {
      ghostEl.textContent = "";
    }
  }

  function ghostSuggestion(v: string): string {
    if (!v) return "";
    const lower = v.toLowerCase();
    const pool = [...PUBLIC_CMDS, ...Object.keys(ALIASES)];
    const match = pool.find((c) => c.startsWith(lower) && c !== lower);
    return match ? match.slice(v.length) : "";
  }

  function setValue(val: string) {
    cmdInput.value = val;
    const end = val.length;
    cmdInput.setSelectionRange(end, end);
    syncFake();
  }

  cmdInput.addEventListener("input", () => {
    syncFake();
    beep(600 + Math.random() * 90, 13); // tap de tecla (pitch ligeramente variable)
  });
  ["keyup", "click", "select", "focus"].forEach((ev) =>
    cmdInput.addEventListener(ev, syncFake)
  );

  cmdInput.addEventListener("keydown", async (e) => {
    if (e.key === "Enter") {
      beep(360, 28); // "intro" más grave
      const val = cmdInput.value;
      if (val.trim()) {
        history.push(val);
        histIdx = history.length;
      }
      setValue("");
      hideHint();
      await execute(val);
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      if (histIdx > 0) {
        histIdx--;
        setValue(history[histIdx] ?? "");
      }
    } else if (e.key === "ArrowDown") {
      e.preventDefault();
      if (histIdx < history.length - 1) {
        histIdx++;
        setValue(history[histIdx] ?? "");
      } else {
        histIdx = history.length;
        setValue("");
      }
    } else if (e.key === "Tab") {
      e.preventDefault();
      const g = ghostSuggestion(cmdInput.value);
      if (g) setValue(cmdInput.value + g);
    } else if (e.key === "ArrowRight") {
      const atEnd = (cmdInput.selectionStart ?? 0) === cmdInput.value.length;
      const g = atEnd ? ghostSuggestion(cmdInput.value) : "";
      if (g) { e.preventDefault(); setValue(cmdInput.value + g); }
      else requestAnimationFrame(syncFake);
    } else if (e.key === "l" && e.ctrlKey) {
      e.preventDefault();
      output.innerHTML = "";
    } else {
      requestAnimationFrame(syncFake);
    }
  });

